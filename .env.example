# ============================================================
#  Checklist Inspecciones Externas - INER
#  Variables de entorno (Vercel + Supabase + Resend)
#
#  COMO USAR:
#   1. Copia este archivo a ".env"   -> cp .env.example .env
#   2. Rellena cada valor siguiendo las instrucciones de abajo.
#   3. En Vercel, carga las mismas variables en:
#      Project -> Settings -> Environment Variables.
#  NO subas ".env" a git (ya esta en .gitignore).
# ============================================================


# ------------------------------------------------------------
# 1) BASE DE DATOS  (Supabase)
# ------------------------------------------------------------
# Donde:  Supabase -> tu proyecto -> boton "Connect" (arriba)
#         o  Project Settings -> Database -> "Connection string".
#
# Necesitas DOS strings:
#   - DATABASE_URL : modo "Transaction pooler" (puerto 6543).
#                    La usa la app en Vercel (serverless).
#   - DIRECT_URL   : modo "Direct connection"  (puerto 5432).
#                    La usa Prisma SOLO para migraciones.
#
# Reemplaza:
#   [PASSWORD]      = la contrasena de la BD (la definiste al crear
#                     el proyecto; puedes resetearla en
#                     Project Settings -> Database -> "Reset database password").
#   [PROJECT-REF]   = el id de tu proyecto (ej. abcd1234efgh5678).
#   [REGION]        = la region (ej. us-east-1, sa-east-1, etc.).
#
# Deja ?pgbouncer=true en DATABASE_URL tal cual (lo exige Prisma con el pooler).

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"


# ------------------------------------------------------------
# 2) CORREO  (Resend)
# ------------------------------------------------------------
# RESEND_API_KEY:
#   Donde:  https://resend.com -> API Keys -> Create API Key
#           (permiso "Sending access"). Empieza con "re_".
#           Se muestra UNA sola vez: copiala al crearla.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# MAIL_FROM:  remitente de los correos.
#   - Para PROBAR ya:        onboarding@resend.dev
#   - En PRODUCCION: una direccion de un dominio verificado en
#     Resend (Domains -> Add Domain + registros DNS).
#     Ej: "Checklist INER <checklist@tudominio.cl>"
MAIL_FROM="onboarding@resend.dev"

# MAIL_TO_SUPERVISOR:  a quien llega la notificacion (Nicolas).
MAIL_TO_SUPERVISOR="nicolas@correo-de-nicolas.cl"


# ------------------------------------------------------------
# 3) APP
# ------------------------------------------------------------
# URL publica de la app.
#   - Local:       http://localhost:3000
#   - Produccion:  https://tu-proyecto.vercel.app  (la da Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ------------------------------------------------------------
# 4) AUTENTICACION  (Auth.js + Google) - solo administradores @iner.cl
# ------------------------------------------------------------
# AUTH_SECRET: clave para firmar la sesion. Genera una con:  npx auth secret
AUTH_SECRET="reemplaza-con-una-clave-larga-aleatoria"

# Google OAuth (Google Cloud Console -> APIs y servicios -> Credenciales ->
# Crear ID de cliente OAuth -> Aplicacion web).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<tu-proyecto>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"


# ------------------------------------------------------------
# 5) STORAGE DE INFORMES  (Supabase Storage)
# ------------------------------------------------------------
# Crea un bucket PRIVADO llamado "informes" en Supabase -> Storage.
# SUPABASE_URL y la SERVICE ROLE key estan en: Supabase -> Settings -> API.
# OJO: la service_role key es secreta (solo backend), NO la expongas en el cliente.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci...service_role..."
SUPABASE_BUCKET="informes"
